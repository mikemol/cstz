    "hasClassView": { "@id": "pff:hasClassView", "@type": "@id" },
    "hasShadow": { "@id": "pff:hasShadow", "@type": "@id" },

    "ordinal": "pff:ordinal",
    "phase": "pff:phase",
    "label": "pff:label",
    "sort": "pff:sort",
    "policy": "pff:policy",
    "truncation": "pff:truncation",
    "congruence": "pff:congruence",
    "isAuthoritative": "pff:isAuthoritative",

    "patchRank": { "@id": "pff:patchRank", "@type": "@id" },
    "leftBoundary": { "@id": "pff:leftBoundary", "@type": "@id" },
    "rightBoundary": { "@id": "pff:rightBoundary", "@type": "@id" },

    "hasPort": { "@id": "pff:hasPort", "@type": "@id" },
